# Copy to .env (next to docker-compose.yml) and fill in.

# --- Image (production / GHCR) ---
GHCR_OWNER=your-github-username   # lowercase
IMAGE_TAG=latest

# --- Auth (required) ---
HOMEPORT_ADMIN_PASSWORD=change-me-please
HOMEPORT_SESSION_SECRET=change-me-to-a-long-random-string   # e.g. openssl rand -hex 32

# --- Multiple hosts (optional) ---
# Aggregate several Docker hosts. JSON array; each host can use any DOCKER_HOST style,
# its own reverse proxy, and its own sshFingerprint. Or add them on the settings page.
# Leave unset to watch just the single host configured below.
# HOMEPORT_HOSTS=[{"name":"this-box"},{"name":"vps","dockerHost":"ssh://user@vps","dockerSshKey":"/ssh/id_ed25519","sshFingerprint":"SHA256:...","npmConfDir":"/npm"}]

# --- Reverse proxy (optional — enables domain mapping) ---
# Auto-detected; or force one: DOMAIN_PROVIDER=npm | nginx | traefik | traefik-file | caddy
# DOMAIN_PROVIDER=

# Nginx Proxy Manager: host path to its generated proxy-host confs.
NPM_HOST_CONF_DIR=/path/to/nginx-proxy-manager/data/nginx/proxy_host

# Plain Nginx: a confs dir (sites-enabled / conf.d) or a single file, mounted read-only.
# NGINX_CONF_DIR=/nginx/sites-enabled

# Traefik (labels): nothing to set — it reads traefik.* labels off your containers.

# Traefik (file provider): path to a dynamic-config file or dir (YAML/TOML), mounted read-only.
# TRAEFIK_FILE=/traefik/dynamic.yml

# Caddy: host path to your Caddyfile (mount it read-only and set CADDYFILE_PATH=/Caddyfile).
# CADDYFILE_HOST_PATH=/path/to/Caddyfile

# --- Docker access ---
# By default homeport talks to the bundled read-only docker-socket-proxy.
# To watch a REMOTE host over SSH instead, set:
#   DOCKER_HOST=ssh://user@your-server
#   DOCKER_SSH_KEY=/ssh/id_ed25519   (mount your key read-only to that path)
# DOCKER_SSH_KEY_PASSPHRASE=
# Pin the remote host key (recommended). Get it with:
#   ssh-keyscan your-server | ssh-keygen -lf -
# DOCKER_SSH_FINGERPRINT=SHA256:...

# --- Appearance (optional) ---
# Fetch real app logos from the dashboard-icons CDN. On by default; set false to stay
# fully offline (monograms + your own hub.icon URLs only).
# HOMEPORT_REMOTE_ICONS=true

# --- Capabilities (tiered opt-in) ---
# homeport is READ-ONLY by default. Each capability is its own opt-in; the comment
# shows what the docker-socket-proxy must additionally allow.
HOMEPORT_ALLOW_CONTROL=false      # start/stop/restart buttons        (proxy: POST=1)
# HOMEPORT_LOGS=true              # container logs viewer — ON by default (read tier)
# HOMEPORT_UPDATE_CHECK=false     # check registries for newer images (proxy: DISTRIBUTION=1)
# HOMEPORT_UPDATE_CHECK_INTERVAL_H=24  # hours between checks per image (counts toward Hub pull limits)
# HOMEPORT_ALLOW_UPDATES=false    # apply updates: pull + recreate    (proxy: IMAGES=1 POST=1)
# HOMEPORT_ALLOW_STACKS=false     # compose stack management          (proxy: POST=1 IMAGES=1 NETWORKS=1 VOLUMES=1; mount a stacks dir)
# HOMEPORT_STACKS_DIR=/stacks
# HOMEPORT_ALLOW_TERMINAL=false   # web terminal (exec into containers) (proxy: EXEC=1 POST=1) — full shell access!
# HOMEPORT_ALLOW_PROXY_ADMIN=false # manage the reverse proxy (no Docker perms; needs provider credentials)
# Proxy-admin credentials (or set them per host on the settings page):
#   NPM:    HOMEPORT_NPM_API_URL=http://npm:81  HOMEPORT_NPM_API_IDENTITY=you@example.com  HOMEPORT_NPM_API_SECRET=...
#   Caddy:  HOMEPORT_CADDY_ADMIN_URL=http://caddy:2019   (private network only — never publish it)
#   Traefik file: reuses TRAEFIK_FILE — mount it READ-WRITE for proxy admin

# --- Settings page persistence ---
# The in-app settings page writes here. The compose file mounts a volume at /data.
HOMEPORT_DATA_DIR=/data

# --- Uptime (optional) ---
# HTTP-ping mapped domains for an up/down dot. On by default.
# HOMEPORT_PING=true

# --- systemd host services (optional) ---
# Show host systemd services. Needs systemctl access (host install, or mount
# /run/systemd + the dbus socket into the container). Off by default.
# HOMEPORT_SYSTEMD=true
# HOMEPORT_SYSTEMD_UNITS=nginx,postgresql   # optional allowlist (default: active + failed)

# --- Background collector / history / alerts (optional) ---
# A background loop snapshots the fleet every N seconds to feed history + alerts.
# HOMEPORT_COLLECTOR_INTERVAL=30        # seconds, min 10
# Persist CPU/RAM history (per-series JSON under <data dir>/stats). On by default.
# HOMEPORT_HISTORY=true
# HOMEPORT_HISTORY_RESOLUTION=60        # seconds per point (advanced)
# HOMEPORT_HISTORY_RETENTION_HOURS=24   # hours kept per series (advanced)
# HOMEPORT_HISTORY_MAX_SERIES=500       # cap tracked series (advanced)
# Per-service down/unhealthy/recovered notifications. Configure channels in the
# settings page (Discord/Slack/ntfy/custom webhooks). Off by default.
# HOMEPORT_ALERTS=true
