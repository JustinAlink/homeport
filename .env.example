# Copy to .env (next to docker-compose.yml) and fill in.

# --- Image (production / GHCR) ---
GHCR_OWNER=your-github-username   # lowercase
IMAGE_TAG=latest

# --- Auth (required) ---
HOMEPORT_ADMIN_PASSWORD=change-me-please
HOMEPORT_SESSION_SECRET=change-me-to-a-long-random-string   # e.g. openssl rand -hex 32

# --- Reverse proxy (optional — enables domain mapping) ---
# Auto-detected; or force one: DOMAIN_PROVIDER=npm | traefik | caddy
# DOMAIN_PROVIDER=

# Nginx Proxy Manager: host path to its generated proxy-host confs.
NPM_HOST_CONF_DIR=/path/to/nginx-proxy-manager/data/nginx/proxy_host

# Traefik: nothing to set — it reads traefik.* labels off your containers.

# Caddy: host path to your Caddyfile (mount it read-only and set CADDYFILE_PATH=/Caddyfile).
# CADDYFILE_HOST_PATH=/path/to/Caddyfile

# --- Docker access ---
# By default homeport talks to the bundled read-only docker-socket-proxy.
# Nothing to set here unless you want to point DOCKER_HOST elsewhere.

# --- Controls (optional) ---
# true enables start/stop buttons. OFF by default — homeport is read-only otherwise.
# Requires the socket proxy to allow writes (set POST=1 on docker-socket-proxy).
HOMEPORT_ALLOW_CONTROL=false
